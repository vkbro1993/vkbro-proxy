# Vkbro-MLX Agent Cache Proxy v2.7.0 环境配置
# 复制此文件为 .env 后按需修改

# ── OMLX 连接 ─────────────────────────────────────────────────
# OMLX 服务地址
# OMLX_URL=http://localhost:8001/v1/chat/completions
# OMLX_API_KEY=SK-OMLX-VKBRO
# OMLX_ADMIN_URL=http://localhost:8001/admin/api/stats
# OMLX_MODELS_URL=http://localhost:8001/v1/models
# OMLX_STATUS_URL=http://localhost:8001/v1/status

# ── Proxy 自身 ────────────────────────────────────────────────
# PROXY_PORT=8000
# PROXY_HOST=127.0.0.1

# ── 缓存 / 锚点 阈值 ──────────────────────────────────────────
# PRE_FREEZE_DELAY=2              # 锚点冻结前需稳定的轮数
# HIT_RATE_HEALTHY=0.7            # 缓存命中率 ≥ 此值为健康
# HIT_RATE_DEGRADED=0.5           # 缓存命中率 ≤ 此值为一般
# HIT_RATE_CRITICAL=0.3           # 缓存命中率 ≤ 此值为需关注
# WINDOW_SIZE=5                   # 命中率滑动窗口大小

# ── SSE / 流式 ────────────────────────────────────────────────
# STREAM_MISS_THRESHOLD=3          # 连续未命中多次进入回退模式

# ── 压缩 ─────────────────────────────────────────────────────
# COMPRESSION_MIN_COUNT=3
# COMPRESSION_COOLDOWN=2
# EPHEMERAL_COMPRESS_THRESHOLD=4000   # 瞬态块 token 数超过此值自动压缩
# EPHEMERAL_COMPRESS_TARGET=2000      # 压缩目标 token 数

# ── 自动检查点 ───────────────────────────────────────────────
# AUTO_CHECKPOINT_BLOCKS=40        # 对话块超过此数触发自动检查点
# AUTO_CHECKPOINT_KEEP=0.35        # 检查点保留比例

# ── HTTP 客户端 ──────────────────────────────────────────────
# HTTP_TIMEOUT=180.0               # 上游请求超时(秒)
# MAX_KEEPALIVE=2                  # 最大 keep-alive 连接数
# ADMIN_TIMEOUT=3.0                # 管理接口超时(秒)
